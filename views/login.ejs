<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion Admin | Roeya</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background: #1a1a1a; display: flex; align-items: center; justify-content: center; height: 100vh;">
    <div style="background: white; padding: 3rem; border-radius: 8px; width: 100%; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
        <h2 style="text-align: center; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 2px;">Admin Login</h2>
        
        <% if (error) { %>
            <div style="background: #fee; color: #c00; padding: 10px; margin-bottom: 1rem; text-align: center; border-radius: 4px;">
                <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            <div style="margin-bottom: 1.5rem;">
                <label>Nom d'utilisateur</label>
                <input type="text" name="username" required style="width: 100%; padding: 0.8rem; margin-top: 0.5rem; border: 1px solid #ddd;">
            </div>
            <div style="margin-bottom: 2rem;">
                <label>Mot de passe</label>
                <input type="password" name="password" required style="width: 100%; padding: 0.8rem; margin-top: 0.5rem; border: 1px solid #ddd;">
            </div>
            <button type="submit" class="btn" style="width: 100%;">Se connecter</button>
        </form>
    </div>
</body>
</html>
