<%- include('header-admin') %>

<div style="margin-bottom: 3rem;">
    <h1 style="font-weight: 300; letter-spacing: 5px; text-transform: uppercase;">Messages Clients</h1>
    <p style="color: #888; font-size: 0.9rem;">Consultation des demandes de contact et assistance</p>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th>CLIENT</th>
                <th>MESSAGE</th>
                <th>DATE</th>
                <th style="text-align: right;">ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof messages !== 'undefined') { %>
                <% for (var i = 0; i < messages.length; i++) { 
                    var msg = messages[i];
                %>
                    <tr style="border-bottom: 1px solid #f0f0f0;">
                        <td style="width: 250px;">
                            <div style="font-weight: 700;"><%= msg.name %></div>
                            <div style="font-size: 0.8rem; color: #666;"><%= msg.email %></div>
                        </td>
                        <td>
                            <div style="padding: 1rem; background: #f9f9f9; border-radius: 4px; font-size: 0.9rem; line-height: 1.6; color: #444;">
                                <%= msg.message %>
                            </div>
                        </td>
                        <td style="width: 150px; font-size: 0.8rem; color: #999;">
                            <%= new Date(msg.created_at).toLocaleString('fr-FR') %>
                        </td>
                        <td style="text-align: right;">
                            <form action="/admin/messages/delete/<%= msg.id %>" method="POST" onsubmit="return confirm('Supprimer ce message ?')">
                                <button type="submit" style="color: #e74c3c; background: none; border: none; cursor: pointer; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                <% } %>
            <% } else { %>
                <tr><td colspan="4" style="text-align:center; padding: 2rem;">Aucun message disponible</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('footer-admin') %>
