<%- include('header-admin') %>

<div style="margin-bottom: 3rem;">
    <h1 style="font-weight: 300; letter-spacing: 5px; text-transform: uppercase;">Console de Gestion</h1>
    <p style="color: #888; font-size: 0.9rem;">Bienvenue dans l'espace exclusif LX LUXOR</p>
</div>

<% 
    var pCount = typeof ordersPending !== 'undefined' ? ordersPending : 0;
    var lCount = typeof lowStockCount !== 'undefined' ? lowStockCount : 0;
%>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
    <div class="card" style="border-left: 4px solid var(--accent-color);">
        <h3 style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #999;">Revenu Total</h3>
        <p style="font-size: 2.2rem; font-weight: 800; margin-top: 10px;">
            <% 
                var total = 0;
                if (typeof orders !== 'undefined') {
                    for (var i = 0; i < orders.length; i++) {
                        total += parseFloat(orders[i].total_price);
                    }
                }
            %>
            <%= total.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) %> DH
        </p>
    </div>
    
    <div class="card" style="border-left: 4px solid var(--primary-color);">
        <h3 style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #999;">Commandes Actives</h3>
        <p style="font-size: 2.2rem; font-weight: 800; margin-top: 10px;"><%= typeof orders !== 'undefined' ? orders.length : 0 %></p>
        <div style="font-size: 0.8rem; color: #f39c12; margin-top: 10px;">Dont <%= pCount %> en attente</div>
    </div>

    <div class="card" style="border-left: 4px solid var(--silver);">
        <h3 style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #999;">Stock Inventaire</h3>
        <p style="font-size: 2.2rem; font-weight: 800; margin-top: 10px;">
            <% 
                var stock = 0;
                if (typeof products !== 'undefined') {
                    for (var k = 0; k < products.length; k++) {
                        stock += products[k].stock_quantity;
                    }
                }
            %>
            <%= stock %>
        </p>
        <div style="font-size: 0.8rem; color: #e74c3c; margin-top: 10px;"><%= lCount %> produits en rupture critique</div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
    <div class="card">
        <h3 style="margin-bottom: 2rem; font-weight: 300; letter-spacing: 2px;">DERNIÈRES VENTES</h3>
        <table>
            <thead>
                <tr>
                    <th>CLIENT</th>
                    <th>DATE</th>
                    <th>TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                    <% 
                        var recentOrders = orders.slice(0, 5);
                        for (var j = 0; j < recentOrders.length; j++) { 
                            var order = recentOrders[j];
                    %>
                        <tr>
                            <td style="font-weight: 600;"><%= order.customer_name %></td>
                            <td style="color: #666;"><%= new Date(order.created_at).toLocaleDateString('fr-FR') %></td>
                            <td style="font-weight: 600;"><%= order.total_price %> DH</td>
                        </tr>
                    <% } %>
                <% } else { %>
                    <tr><td colspan="3">Aucune vente enregistrée.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 2rem; font-weight: 300; letter-spacing: 2px;">MESSAGES RÉCENTS</h3>
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <% for (var m = 0; m < messages.slice(0, 3).length; m++) { 
                var msg = messages[m];
            %>
                <div style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eee;">
                    <div style="font-weight: 700; font-size: 0.85rem;"><%= msg.name %></div>
                    <div style="font-size: 0.8rem; color: #888; margin-bottom: 5px;"><%= msg.email %></div>
                    <div style="font-size: 0.8rem; font-style: italic; color: #555; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        "<%= msg.message %>"
                    </div>
                </div>
            <% } %>
            <a href="/admin/messages" style="display: block; text-align: center; color: var(--primary-color); font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">Voir tout</a>
        <% } else { %>
            <p style="font-size: 0.8rem; color: #999;">Aucun message reçu.</p>
        <% } %>
    </div>
</div>

<%- include('footer-admin') %>
