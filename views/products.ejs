<%- include('header-admin') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
    <div>
        <h1 style="font-weight: 300; letter-spacing: 5px; text-transform: uppercase;">Inventaire Prestige</h1>
        <p style="color: #888; font-size: 0.9rem;">Gestion des articles et de la disponibilité</p>
    </div>
    <button onclick="document.getElementById('add-modal').style.display='block'" class="btn-luxe" style="background: var(--primary-color); color: var(--white); border: none; padding: 0.8rem 2rem; font-size: 0.8rem;">+ Nouvel Article</button>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th style="width: 100px;">VISUEL</th>
                <th>DESCRIPTION PRODUIT</th>
                <th style="width: 150px;">CATÉGORIE</th>
                <th style="width: 120px;">PRIX</th>
                <th style="width: 120px;">STOCK</th>
                <th style="text-align: right;">ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            <% for (var i = 0; i < products.length; i++) { 
                var p = products[i];
            %>
                <tr style="border-bottom: 1px solid #f0f0f0;">
                    <td>
                        <div style="width: 60px; height: 60px; overflow: hidden; border-radius: 4px; border: 1px solid #eee;">
                            <img src="<%= p.image_url %>" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                    </td>
                    <td>
                        <div style="font-weight: 700; margin-bottom: 2px;"><%= p.name %></div>
                        <div style="font-size: 0.75rem; color: #888; max-width: 400px; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            <%= p.description %>
                        </div>
                    </td>
                    <td><span style="font-size: 0.75rem; letter-spacing: 1px; color: var(--silver); text-transform: uppercase;"><%= p.category || 'N/A' %></span></td>
                    <td style="font-weight: 700;"><%= parseFloat(p.price).toFixed(2) %> DH</td>
                    <td>
                        <span style="font-weight: 800; <%= p.stock_quantity < 5 ? 'color: red;' : 'color: #27ae60;' %>">
                            <%= p.stock_quantity %> units
                        </span>
                    </td>
                    <td style="text-align: right; display: flex; gap: 1rem; justify-content: flex-end; align-items: center;">
                        <button 
                            class="edit-btn"
                            data-id="<%= p.id %>"
                            data-name="<%= p.name %>"
                            data-price="<%= p.price %>"
                            data-stock="<%= p.stock_quantity %>"
                            data-category="<%= p.category %>"
                            data-desc="<%= p.description %>"
                            onclick="openEditModalFromData(this)"
                            style="background: none; border: none; color: #3498db; cursor: pointer; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
                            Modifier
                        </button>
                        <form action="/admin/products/delete/<%= p.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir retirer cet article de la collection ?')">
                            <button type="submit" style="background: none; border: none; color: #e74c3c; cursor: pointer; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Retirer</button>
                        </form>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Add Product Modal -->
<div id="add-modal" style="display:none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 2000; backdrop-filter: blur(5px);">
    <div style="background: white; width: 600px; margin: 5vh auto; padding: 4rem; border-radius: 0; box-shadow: 0 20px 50px rgba(0,0,0,0.5);">
        <h2 style="font-weight: 300; letter-spacing: 3px; margin-bottom: 2rem; text-align: center; text-transform: uppercase;">Ajouter à la Collection</h2>
        <form action="/admin/products/add" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Nom du Modèle</label>
                    <input type="text" name="name" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Marque / Catalogue</label>
                    <select name="category" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem; background: transparent;">
                        <% if (typeof categories !== 'undefined') { %>
                            <% for (var c = 0; c < categories.length; c++) { %>
                                <option value="<%= categories[c].name %>"><%= categories[c].name %></option>
                            <% } %>
                        <% } else { %>
                            <option value="">Aucune catégorie disponible</option>
                        <% } %>
                    </select>
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Prix de Vente (DH)</label>
                    <input type="number" step="0.01" name="price" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Unités en Stock</label>
                    <input type="number" name="stock_quantity" value="10" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Description détaillée</label>
                <textarea name="description" rows="3" style="width: 100%; border: 1px solid #eee; padding: 15px; margin-top: 10px; outline: none; font-size: 0.9rem;"></textarea>
            </div>

            <div style="margin-bottom: 3rem;">
                <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Image Haute Définition</label><br>
                <input type="file" name="image" required style="margin-top: 15px; font-size: 0.8rem;">
            </div>

            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn-luxe" style="flex:2; background: #000; color: #fff; border: none;">Enregistrer dans la collection</button>
                <button type="button" onclick="document.getElementById('add-modal').style.display='none'" class="btn-luxe" style="flex:1;">Annuler</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Product Modal -->
<div id="edit-modal" style="display:none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 2000; backdrop-filter: blur(5px);">
    <div style="background: white; width: 600px; margin: 5vh auto; padding: 4rem; border-radius: 0; box-shadow: 0 20px 50px rgba(0,0,0,0.5);">
        <h2 style="font-weight: 300; letter-spacing: 3px; margin-bottom: 2rem; text-align: center; text-transform: uppercase;">Modifier l'Article</h2>
        <form id="edit-form" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Nom du Modèle</label>
                    <input type="text" name="name" id="edit-name" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Marque / Catalogue</label>
                    <select name="category" id="edit-category" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem; background: transparent;">
                        <% if (typeof categories !== 'undefined') { %>
                            <% for (var c = 0; c < categories.length; c++) { %>
                                <option value="<%= categories[c].name %>"><%= categories[c].name %></option>
                            <% } %>
                        <% } %>
                    </select>
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Prix de Vente (DH)</label>
                    <input type="number" step="0.01" name="price" id="edit-price" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Unités en Stock</label>
                    <input type="number" name="stock_quantity" id="edit-stock" required style="width: 100%; border: none; border-bottom: 1px solid #ddd; padding: 10px 0; outline: none; font-size: 1rem;">
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Description détaillée</label>
                <textarea name="description" id="edit-description" rows="3" style="width: 100%; border: 1px solid #eee; padding: 15px; margin-top: 10px; outline: none; font-size: 0.9rem;"></textarea>
            </div>

            <div style="margin-bottom: 3rem;">
                <label style="font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: #888;">Nouvelle Image (Optionnel)</label><br>
                <input type="file" name="image" style="margin-top: 15px; font-size: 0.8rem;">
            </div>

            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn-luxe" style="flex:2; background: #000; color: #fff; border: none;">Mettre à jour</button>
                <button type="button" onclick="document.getElementById('edit-modal').style.display='none'" class="btn-luxe" style="flex:1;">Annuler</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModalFromData(btn) {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const price = btn.getAttribute('data-price');
        const stock = btn.getAttribute('data-stock');
        const desc = btn.getAttribute('data-desc');
        const cat = btn.getAttribute('data-category');

        document.getElementById('edit-form').action = '/admin/products/update/' + id;
        document.getElementById('edit-name').value = name;
        document.getElementById('edit-price').value = price;
        document.getElementById('edit-stock').value = stock;
        document.getElementById('edit-description').value = desc;
        document.getElementById('edit-category').value = cat;
        document.getElementById('edit-modal').style.display = 'block';
    }
</script>

<%- include('footer-admin') %>
